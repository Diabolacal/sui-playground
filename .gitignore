# ─────────────────────────────────────────────────────────────────────────
# Workflow Scaffold .gitignore
# ─────────────────────────────────────────────────────────────────────────

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/prompts/
!.vscode/mcp.json

# Environment & secrets
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# Node.js (if applicable)
node_modules/
dist/
build/
*.tgz
.npm
.eslintcache

# ZK proof artifacts (large binary files)
ptau/
*.ptau
*.zkey
*.wasm
*.r1cs
*.sym

# Python (if applicable)
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# Working memory (agent ephemeral files — not committed)
docs/working_memory/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Local notes (may contain addresses, keys, sensitive local context)
notes/

# Temporary files
tmp_*
temp_*
*.tmp
*.bak
*.swp
*~
